from multiprocessing import Process, Manager
import os
from copy import deepcopy


def f(l):
    li = deepcopy(l) # copy all elements including elements with references
    li.reverse()
    print(li)






if __name__ == '__main__':
    manager = Manager()
    l = manager.list(range(10))
	# Manager manages list
    p1 = Process(target=f, args=(l,))
    p2 = Process(target=f, args=(l,))
    p3 = Process(target=f, args=(l,))        

    p1.start()
    p2.start()
    p3.start()

    p1.join()
    p2.join()
    p3.join()
